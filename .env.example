# 🔐 Environment Variables — QubicSecure

# ────────────────────────────────────────────────────────────
# LLM PROVIDER CONFIGURATION
# Choose ONE provider and add its API key.
# Leave all blank to run in static-only mode (no LLM needed).
# ────────────────────────────────────────────────────────────

# Active provider: groq | gemini | openai | anthropic
LLM_PROVIDER=groq

# ── Groq (Recommended — fast, generous free tier) ──────────
# Get your key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama3-70b-8192   # default — options: mixtral-8x7b-32768, gemma2-9b-it

# ── Google Gemini ──────────────────────────────────────────
# Get your key at: https://aistudio.google.com
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-1.5-flash   # default

# ── OpenAI ────────────────────────────────────────────────
# Get your key at: https://platform.openai.com
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o-mini   # default

# ── Anthropic Claude ──────────────────────────────────────
# Get your key at: https://console.anthropic.com
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-3-haiku-20240307   # default

# ────────────────────────────────────────────────────────────
# EXTERNAL STATIC ANALYSIS API (Optional — not yet integrated)
# ────────────────────────────────────────────────────────────
# STATIC_ANALYSIS_API_KEY=your_api_key_here
# STATIC_ANALYSIS_API_ENDPOINT=https://api.example.com/analyze

# ────────────────────────────────────────────────────────────
# APP
# ────────────────────────────────────────────────────────────
NODE_ENV=development
